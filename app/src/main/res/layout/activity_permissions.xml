<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Övergripande status -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/overallStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Kontrollerar…" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenAppSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="⚙️  Öppna appinställningar"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Normala behörigheter -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NORMALA BEHÖRIGHETER"
                    android:textSize="11sp"
                    android:textColor="@color/textSecondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/statusReceiveSms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/colorSurfaceVariant"
                    android:text="…" />

                <TextView
                    android:id="@+id/statusNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/colorSurfaceVariant"
                    android:text="…" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestNormal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🔐  Begär SMS- och notisbehörigheter"
                    android:textColor="@color/textOnPrimary"
                    android:textSize="15sp"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Systembehörigheter -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SYSTEMBEHÖRIGHETER"
                    android:textSize="11sp"
                    android:textColor="@color/textSecondary"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/statusBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/colorSurfaceVariant"
                    android:text="…" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:id="@+id/btnOpenBattery"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔋  Undanta från batterioptimering"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/statusOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/colorSurfaceVariant"
                    android:text="…" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:id="@+id/btnOpenOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🪟  Tillåt visning över andra appar"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/statusFullscreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/textPrimary"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/colorSurfaceVariant"
                    android:text="…" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:id="@+id/btnOpenFullscreen"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📱  Tillåt helskärmsnotis (Android 14+)"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:id="@+id/btnOpenNotifSettings"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔔  Öppna notifikationsinställningar"
                    android:textColor="@color/colorPrimary"
                    android:textSize="14sp"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="10dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
