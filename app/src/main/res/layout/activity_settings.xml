<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Sektion: SMS-filter -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS-FILTER"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Avsändarnummer"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nummer larmsms kommer ifrån. Kommaseparera flera, t.ex. 3315,112"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSenderNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:hint="Avsändarnummer (kommaseparera flera, t.ex. 3315,112)" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nyckelord för TOTALLARM"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Text i SMS som identifierar totallarm"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTotalAlarmKeyword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="TOTALLARM" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nyckelord för vanligt larm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Text i SMS som identifierar vanligt larm (VRR: LARM)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlarmKeyword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="LARM" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sektion: Larmtyper -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LARMTYPER"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Totallarm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Slå av om du inte vill larmas vid totallarm (t.ex. semester eller sjukdom). Vanliga larm under schema påverkas inte."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTotalAlarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trigga larm vid TOTALLARM"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Endast vibration"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Endast vibration (inget ljud)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchVibrationOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Endast vibration (inget ljud)"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Text-to-speech larm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appen säger 'TOTALLARM!' med röst"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchUseTts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tala larmet (Text-to-speech)" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sektion: Testläge -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TESTLÄGE"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS-testläge"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="När PÅ: appen triggar på SMS från ALLA avsändare (inte bara 3315). Slå på, smsa TOTALLARM eller LARM till dig själv, verifiera att larmet går. Kom ihåg att slå av igen!"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSmsTestMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMS-testläge (alla avsändare)"
                    android:layout_marginBottom="12dp" />

                <!-- Varningstext -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️  Testläge bör bara vara aktivt vid test. Glöm inte att stänga av!"
                    android:textSize="13sp"
                    android:textColor="#E65100"
                    android:background="#FFF3E0"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sektion: Beteende -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BETEENDE"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <!-- Auto-stäng av -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto-stäng av larm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Auto-stäng av efter X minuter (0 = aldrig)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAutoDismissMinutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:hint="10" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Ficklampa strobe -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ficklampa vid larm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ficklampa blinkar vid larm"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchFlashlightStrobe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ficklampa blinkar vid larm"
                    android:layout_marginBottom="20dp" />

                <!-- Tyst nattetid -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tyst nattetid"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vanliga larm är tysta under dessa tider (totallarm larmar alltid)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchQuietHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tyst nattetid (vanliga larm)"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/layoutQuietHoursTimes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Från"
                            android:textSize="12sp"
                            android:textColor="#757575"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvQuietStart"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#B71C1C"
                            android:text="22:00" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Till"
                            android:textSize="12sp"
                            android:textColor="#757575"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvQuietEnd"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#B71C1C"
                            android:text="06:00" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spara-knapp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Spara"
                app:backgroundTint="#B71C1C" />

        </LinearLayout>

        <!-- Sektion: Export/Import -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EXPORT / IMPORT"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exportera eller importera alla inställningar som JSON."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:id="@+id/btnExportSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Exportera inställningar"
                    android:textColor="#B71C1C"
                    app:strokeColor="#B71C1C"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:id="@+id/btnImportSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Importera inställningar"
                    android:textColor="#B71C1C"
                    app:strokeColor="#B71C1C" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
