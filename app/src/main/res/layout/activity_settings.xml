<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Sektion: SMS-filter -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS-FILTER"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Avsändarnummer"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nummer som larmsms kommer ifrån (VRR: 3315)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSenderNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:hint="3315" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nyckelord för TOTALLARM"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Text i SMS som identifierar totallarm"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTotalAlarmKeyword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="TOTALLARM" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nyckelord för vanligt larm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Text i SMS som identifierar vanligt larm (VRR: LARM)"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#B71C1C">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAlarmKeyword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="LARM" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sektion: Larmtyper -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LARMTYPER"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Totallarm"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Slå av om du inte vill larmas vid totallarm (t.ex. semester eller sjukdom). Vanliga larm under schema påverkas inte."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTotalAlarm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trigga larm vid TOTALLARM" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sektion: Testläge -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TESTLÄGE"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS-testläge"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="När PÅ: appen triggar på SMS från ALLA avsändare (inte bara 3315). Slå på, smsa TOTALLARM eller LARM till dig själv, verifiera att larmet går. Kom ihåg att slå av igen!"
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSmsTestMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMS-testläge (alla avsändare)"
                    android:layout_marginBottom="12dp" />

                <!-- Varningstext -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠️  Testläge bör bara vara aktivt vid test. Glöm inte att stänga av!"
                    android:textSize="13sp"
                    android:textColor="#E65100"
                    android:background="#FFF3E0"
                    android:padding="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spara-knapp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Spara"
                app:backgroundTint="#B71C1C" />

        </LinearLayout>

        <!-- Sektion: Export/Import -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EXPORT / IMPORT"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Exportera eller importera alla inställningar som JSON."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:id="@+id/btnExportSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Exportera inställningar"
                    android:textColor="#B71C1C"
                    app:strokeColor="#B71C1C"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:id="@+id/btnImportSettings"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Importera inställningar"
                    android:textColor="#B71C1C"
                    app:strokeColor="#B71C1C" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
